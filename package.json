{
  "name": "rondine",
  "private": true,
  "version": "0.1.0",
  "description": "Rondine — 軽くて美しく、AIに勝手に中身を渡さない、所有したくなるメール",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tauri dev",
    "dev:renderer": "vite",
    "build": "tauri build",
    "build:renderer": "vite build",
    "tauri": "tauri",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen:bindings": "cd src-tauri && cargo test --lib export_bindings",
    "sync:identity": "node scripts/sync-app-identity.mjs",
    "predev": "node scripts/sync-app-identity.mjs",
    "prebuild": "node scripts/sync-app-identity.mjs"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "happy-dom": "^15.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "markdownlint-cli2": "^0.20.0",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-log": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-store": "^2",
    "i18next": "^23.16.0",
    "libphonenumber-js": "^1.13.7",
    "lucide-react": "^1.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.0",
    "zustand": "^5.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  }
}
